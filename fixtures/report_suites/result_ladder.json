{
  "id": "result-ladder",
  "title": "Cave Result Ladder",
  "description": "A predefined suite of reports that moves from reading one episode, to mechanism and population checks, to pressure and emergence-style runs.",
  "output_root": "out/report_suites/result-ladder",
  "tiers": [
    {
      "id": "walkthrough",
      "title": "Walkthrough",
      "description": "Show how to read a Cave episode through coordinated presentation, memory, timeline, prediction, correction, and topology views."
    },
    {
      "id": "mechanism",
      "title": "Mechanism And Population",
      "description": "Show that sensing, attention, prediction, value, workspace compression, subject configuration, and population geometry are distinguishable."
    },
    {
      "id": "emergence",
      "title": "Emergence And Pressure",
      "description": "Show the bridge from predefined Cave roles toward pressure-shaped and developmental substrate behavior."
    },
    {
      "id": "causal_probes",
      "title": "Causal Probes",
      "description": "Show intervention/control contrasts for the role dependencies claimed by the causal probe reports."
    }
  ],
  "entries": [
    {
